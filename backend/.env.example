# Configuración del backend del Refugio Amor de 4 Patas

# Clave secreta para firmar los tokens JWT (cambiar en producción)
SECRET_KEY=cambia-esta-clave-en-produccion-refugio-4-patas

# Algoritmo y duración de los tokens
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Ruta de la base de datos SQLite
DATABASE_URL=sqlite:///./refugio.db
